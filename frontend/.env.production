# Production Environment Variables
VITE_APP_ENV=production
VITE_MODE=production

# OpenWeatherMap API Key
VITE_OPENWEATHER_API_KEY=71cec26aae7f67e7f8d04e6baf1aef33

# Use proxy untuk hide API URL (nginx reverse proxy)
VITE_USE_PROXY=true

# Real-time mode (mqtt or api)
VITE_REALTIME_MODE=mqtt
# Polling interval in milliseconds (used when mode=api)
VITE_REALTIME_POLL_INTERVAL_MS=5000

# Disable direct API URL in production
# API akan di-access via relative path /api yang di-proxy oleh nginx
# VITE_API_BASE_URL=/api
# VITE_WS_URL=/ws

# Disable logging in production
VITE_ENABLE_LOGGING=false

# MQTT over WebSocket (required for browser publish)
VITE_MQTT_BROKER=mqtt.seano.cloud
VITE_MQTT_PORT=443
VITE_MQTT_PROTOCOL=wss
VITE_MQTT_PATH=/mqtt
VITE_MQTT_WS_URL=wss://mqtt.seano.cloud/mqtt
VITE_MQTT_USERNAME=seanomqtt
VITE_MQTT_PASSWORD=Seano2025*
